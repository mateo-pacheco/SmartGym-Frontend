# Dependencias y artefactos (se reconstruyen en el build)
node_modules
dist
dist-ssr
coverage
*.tsbuildinfo

# Git y tooling
.git
.gitignore
.github

# Carpetas de asistentes de IA
.agents
.codex
.claude

# Variables de entorno — NUNCA entran a la imagen (la config es de runtime).
