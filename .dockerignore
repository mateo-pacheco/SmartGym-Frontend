.env
.env.*
*.local

# Los propios artefactos de Docker y docs
Dockerfile
.dockerignore
docker-compose.yml
*.md

# Media y capturas sueltas en la raíz (los assets reales viven en public/)
/foto*.jpeg
/foto*.jpg
/video*.mp4
/ucacue-logo-centro-mediacion.png
